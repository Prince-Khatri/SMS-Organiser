<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activities.MainActivity">

    <TextView
        android:id="@+id/appName"
        android:layout_width="285dp"
        android:layout_height="35dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="32dp"
        android:text="Smart SMS Organiser"
        android:textAlignment="center"
        android:textSize="24sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="51dp"
        android:layout_height="46dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        app:layout_constraintEnd_toStartOf="@+id/appName"
        app:layout_constraintHorizontal_bias="0.851"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:srcCompat="@tools:sample/avatars" />

    <HorizontalScrollView
        android:id="@+id/horizontalCategorySelector"
        android:layout_width="357dp"
        android:layout_height="50dp"
        app:layout_constraintBottom_toTopOf="@+id/messagesScrollView"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.551"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/appName"
        app:layout_constraintVertical_bias="0.51">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <com.google.android.material.chip.ChipGroup
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <com.google.android.material.chip.Chip
                    android:id="@+id/allChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="All" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/personalChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Personal" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/otpChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OTP" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/transactionalChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Transactional" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/onlineOrdersChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Online-Orders" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/updatesChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="updates" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/spamChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SPAM" />


                <com.google.android.material.chip.Chip
                    android:id="@+id/promotionChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Promotion" />


            </com.google.android.material.chip.ChipGroup>
        </LinearLayout>
    </HorizontalScrollView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/messagesScrollView"
        android:layout_width="344dp"
        android:layout_height="514dp"
        android:layout_marginBottom="4dp"
        app:layout_constraintBottom_toTopOf="@+id/navigationView"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/navigationView"
        android:layout_width="0dp"
        android:layout_height="100dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:menu="@menu/bottom_nav_menu" />

</androidx.constraintlayout.widget.ConstraintLayout>